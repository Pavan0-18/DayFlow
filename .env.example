# ══════════════════════════════════════
# NEXTAUTH
# ══════════════════════════════════════
# Generate secret: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# ══════════════════════════════════════
# OAUTH PROVIDERS
# ══════════════════════════════════════
# Google: console.cloud.google.com → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Copy this file to .env.local (Next.js + Prisma npm scripts load .env.local).
#
# ══════════════════════════════════════
# DATABASE (Supabase)
# ══════════════════════════════════════
# With pgbouncer (for Prisma in serverless):
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:6543/postgres?pgbouncer=true&connection_limit=1
# Direct connection (for migrations):
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres

# ══════════════════════════════════════
# SUPABASE
# ══════════════════════════════════════
NEXT_PUBLIC_SUPABASE_URL=https://[REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ══════════════════════════════════════
# AI (OpenRouter)
# ══════════════════════════════════════
# Get from: openrouter.ai/keys (free tier available)
OPENROUTER_API_KEY=

# ══════════════════════════════════════
# RATE LIMITING (Upstash)
# ══════════════════════════════════════
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ══════════════════════════════════════
# ERROR TRACKING (Sentry) - deferred
# ══════════════════════════════════════
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
