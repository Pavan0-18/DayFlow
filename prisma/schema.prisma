generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── NextAuth Required ───────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core Domain ─────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  tasks           Task[]
  dailyLogs       DailyLog[]
  scheduledTasks  ScheduledTask[]
  achievements    UserAchievement[]
  settings        UserSettings?

  @@index([email])
}

model Task {
  id          String   @id @default(cuid())
  userId      String
  title       String   @db.VarChar(60)
  description String?  @db.VarChar(200)
  category    String   @default("Personal")
  color       String   @default("#6366F1")
  icon        String   @default("✅")
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  logItems       DailyLogItem[]
  scheduledTasks ScheduledTask[]

  @@index([userId])
  @@index([userId, isActive])
  @@index([userId, sortOrder])
}

model DailyLog {
  id        String         @id @default(cuid())
  userId    String
  date      DateTime       @db.Date
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items DailyLogItem[]

  @@unique([userId, date])
  @@index([userId])
  @@index([userId, date])
}

model DailyLogItem {
  id          String    @id @default(cuid())
  dailyLogId  String
  taskId      String
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  dailyLog DailyLog @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)
  task     Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([dailyLogId, taskId])
  @@index([dailyLogId])
  @@index([taskId])
}

model ScheduledTask {
  id        String   @id @default(cuid())
  userId    String
  taskId    String
  date      DateTime @db.Date
  startTime String   @db.VarChar(5)
  endTime   String   @db.VarChar(5)
  priority  Priority @default(MEDIUM)
  duration  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
}

model UserSettings {
  id                String   @id @default(cuid())
  userId            String   @unique
  theme             Theme    @default(SYSTEM)
  weekStartDay      WeekDay  @default(MONDAY)
  reminderTime      String   @default("08:00")
  reminderEnabled   Boolean  @default(true)
  eveningSummary    Boolean  @default(true)
  achievementAlerts Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Enums ───────────────────────────────────────────────────────

enum Priority {
  HIGH
  MEDIUM
  LOW
}

enum Theme {
  LIGHT
  DARK
  SYSTEM
}

enum WeekDay {
  MONDAY
  SUNDAY
}
